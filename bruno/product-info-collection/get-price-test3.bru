meta {
  name: Test 3 - Request at 21:00 on June 14
  type: http
  seq: 3
}

get {
  url: http://localhost:8080/api/v1/prices?applicationDate=2020-06-14T21:00:00&productId=35455&brandId=1
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.productId: eq 35455
  res.body.brandId: eq 1
  res.body.priceList: eq 1
  res.body.price: eq 35.5
}