meta {
  name: Test 4 - Request at 10:00 on June 15
  type: http
  seq: 4
}

get {
  url: http://localhost:8080/api/v1/prices?applicationDate=2020-06-15T10:00:00&productId=35455&brandId=1
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.productId: eq 35455
  res.body.brandId: eq 1
  res.body.priceList: eq 3
  res.body.price: eq 30.5
}